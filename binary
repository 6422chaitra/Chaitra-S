#include <stdio.h>
#include <stdlib.h>

int findDuplicate(int arr[], int n) {
    int slow = arr[0];
    int fast = arr[0];

    do {
        slow = arr[slow];
        fast = arr[arr[fast]];
    } while (slow != fast);

    slow = arr[0];
    while (slow != fast) {
        slow = arr[slow];
        fast = arr[fast];
    }

    return slow;
}

int main() {
    int n;

    printf("Enter size of array (n > 1): ");
    if (scanf("%d", &n) != 1 || n <= 1) {
        printf("Invalid size.\n");
        return 1;
    }

    int *arr = (int *)malloc(n * sizeof(int));
    if (!arr) {
        printf("Memory allocation failed.\n");
        return 1;
    }

    printf("Enter %d integers in range [1, %d]:\n", n, n - 1);
    for (int i = 0; i < n; i++) {
        if (scanf("%d", &arr[i]) != 1 || arr[i] < 1 || arr[i] > n - 1) {
            printf("Invalid input. Must be in range [1, %d].\n", n - 1);
            free(arr);
            return 1;
        }
    }

    int duplicate = findDuplicate(arr, n);
    printf("Duplicate element is: %d\n", duplicate);

    free(arr);
    return 0;
}