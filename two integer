def max_product_pair(arr):
    # Input validation
    if not isinstance(arr, list) or len(arr) < 2:
        raise ValueError("Input must be a list with at least two integers.")

    # Ensure all elements are integers
    if not all(isinstance(x, int) for x in arr):
        raise ValueError("All elements in the array must be integers.")

    # Sort the array
    arr.sort()

    product1 = arr[-1] * arr[-2]
    product2 = arr[0] * arr[1]

    if product1 >= product2:
        return product1, arr[-2], arr[-1]
    else:
        return product2, arr[0], arr[1]


# Example usage
if __name__ == "__main__":
    try:
        nums = [ -10, -3, 5, 6, -2 ]
        max_product, num1, num2 = max_product_pair(nums)
        print(f"Maximum product is {max_product} from pair ({num1}, {num2})")
    except ValueError as e:
        print(f"Error: {e}")
